                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
                  "  pm.collectionVariables.set('deviceId', data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me/devices",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me",
                "devices"
              ]
            }
          }
        },
        {
          "name": "Revoke Device",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me/devices/{{deviceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me",
                "devices",
                "{{deviceId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}