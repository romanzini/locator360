# ============================================================
# Family Locator — Variáveis de Ambiente (Desenvolvimento)
# ============================================================
# Copie este arquivo para .env e ajuste conforme necessário.
# NUNCA commite o .env com credenciais reais.
# ============================================================

# --- Aplicação ---
APP_NAME=family-locator
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL + PostGIS ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=family_locator
POSTGRES_USER=fl_user
POSTGRES_PASSWORD=fl_secret_dev
POSTGRES_SCHEMA=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- JWT ---
JWT_SECRET=dev-jwt-secret-change-in-production-must-be-at-least-256-bits-long!!
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
